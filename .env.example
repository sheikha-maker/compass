# ─── Required for auth + cloud persistence ────────────────────────────────────
# 1. Create a free Supabase project at https://supabase.com
# 2. Copy the "Connection string" (URI) from Project Settings → Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# 3. Generate a secret:  openssl rand -base64 32
BETTER_AUTH_SECRET="your-random-secret-here"

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set this to your production URL once deployed
NEXT_PUBLIC_SITE_URL="https://v0-premedcompass.vercel.app"
